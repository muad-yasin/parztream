@echo off
rem Copy this file to C:\ProgramData\parztream\parztream.env.bat (not inside
rem the project checkout) and fill in real values -- it contains a password.

set PARZTREAM_MEDIA_DIRS=C:\Media\Music;C:\Media\Videos
set PARZTREAM_DB_PATH=C:\ProgramData\parztream\parztream.db
set PARZTREAM_USERNAME=parztream
set PARZTREAM_PASSWORD=change-me
rem Keeps everyone logged in across restarts; without this, a fresh random
rem key (and everyone logged out) happens every restart. Generate a real one
rem with: python -c "import secrets; print(secrets.token_hex(32))"
set PARZTREAM_SECRET_KEY=change-me-too
