# Copy this file to /etc/parztream/parztream.env (not inside the project
# checkout) and fill in real values. It contains a password, so keep its
# permissions tight:
#   sudo mkdir -p /etc/parztream
#   sudo cp parztream.env.example /etc/parztream/parztream.env
#   sudo chmod 600 /etc/parztream/parztream.env

PARZTREAM_MEDIA_DIRS=/path/to/music:/path/to/videos
PARZTREAM_DB_PATH=/opt/parztream/parztream.db
PARZTREAM_USERNAME=parztream
PARZTREAM_PASSWORD=change-me
# Keeps everyone logged in across restarts; without this, a fresh random key
# (and everyone logged out) happens on every restart. Generate a real one
# with: python3 -c "import secrets; print(secrets.token_hex(32))"
PARZTREAM_SECRET_KEY=change-me-too
